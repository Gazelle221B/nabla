---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// 単元(lessons コレクション)の記事ページ。URL はサブジェクト階層を除いたファイル名スラッグ
// (例: geometry/pythagorean-theorem → /lessons/pythagorean-theorem/)。
export async function getStaticPaths() {
	const lessons = await getCollection('lessons');
	return lessons.map((entry) => ({
		params: { slug: entry.id.split('/').pop() },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, learningGoals } = entry.data;
---

<BaseLayout title={title}>
	<main class="lesson">
		<h1>{title}</h1>

		<section class="goals" aria-labelledby="goals-heading">
			<h2 id="goals-heading">この単元の学習目標</h2>
			<ul>
				{learningGoals.map((goal) => <li>{goal}</li>)}
			</ul>
		</section>

		<Content />
	</main>
</BaseLayout>

<style>
	.lesson {
		max-width: 44rem;
		margin: 0 auto;
		padding: 1.5rem 1.25rem 4rem;
		line-height: 1.8;
	}
	.goals {
		margin: 1.5rem 0;
		padding: 0.75rem 1.25rem;
		border-left: 3px solid var(--nabla-accent-secondary, #e0a94b);
		background: rgba(224, 169, 75, 0.08);
		border-radius: 0 8px 8px 0;
	}
	.goals h2 {
		margin-top: 0.25rem;
		font-size: 1.05rem;
	}
	.lesson :global(details) {
		margin: 1rem 0;
		padding: 0.5rem 1rem;
		border: 1px solid var(--nabla-grid, #33384a);
		border-radius: 8px;
	}
	.lesson :global(summary) {
		cursor: pointer;
		font-weight: 600;
	}
</style>
